---
export interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <!-- Länkar till snygga typsnitt (Great Vibes för rubriker, Montserrat för brödtext) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    /* Här definierar vi det nya snygga typsnittet */
    --font-heading: 'Great Vibes', cursive;
    --font-body: 'Montserrat', sans-serif;
    --accent-green: #A8D5BA;
    --text-main: #2C3E35;
    --bg-color: #F7F9F8;
  }
  body {
    font-family: var(--font-body);
    background-color: var(--bg-color);
    color: var(--text-main);
    margin: 0;
    padding: 0;
  }
</style>