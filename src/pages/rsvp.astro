---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
---

<Layout title="OSA | Ahlbergs Bröllop">
  <main class="page-container">
    <Navigation />
    
    <article class="content-wrapper">
      <h1 class="page-title">OSA</h1>
      <p class="subtitle">Vänligen meddela om ni kan komma senast den 1 september 2026.</p>
      
      <!-- Formspree Endpoint Integrated -->
      <form class="rsvp-form" action="https://formspree.io/f/xqevkbdl" method="POST">
        
        <div class="form-group">
          <label for="fullName">För- och efternamn</label>
          <input type="text" id="fullName" name="fullName" required placeholder="Anna & Karl Andersson" />
        </div>

        <div class="form-group">
          <label for="email">E-postadress</label>
          <input type="email" id="email" name="email" required placeholder="anna@exempel.se" />
        </div>

        <div class="form-group">
          <label>Kommer ni?</label>
          <div class="radio-group">
            <label class="radio-label">
              <input type="radio" name="attending" value="yes" required />
              <span>Ja, vi kommer gärna!</span>
            </label>
            <label class="radio-label">
              <input type="radio" name="attending" value="no" />
              <span>Nej, vi kan tyvärr inte komma.</span>
            </label>
          </div>
        </div>

        <div class="form-group">
          <label for="dietary">Specialkost / Allergier</label>
          <input type="text" id="dietary" name="dietary" placeholder="t.ex. vegetarian, glutenfri" />
        </div>

        <div class="form-group">
          <label for="message">Hälsning till brudparet (Frivilligt)</label>
          <textarea id="message" name="message" rows="4" placeholder="Ser fram emot det!"></textarea>
        </div>

        <button type="submit" class="submit-button">Skicka OSA</button>
      </form>
    </article>
  </main>
</Layout>

<style>
  .page-container {
    min-height: 100vh;
    padding: clamp(2rem, 5vw, 4rem) 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .content-wrapper {
    width: 100%;
    max-width: 600px;
    background: #FFFFFF;
    padding: clamp(2rem, 5vw, 4rem);
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    margin-top: 2rem;
  }

  .page-title {
    font-family: var(--font-heading); /* Tillagt för att aktivera skrivstilen */
    font-size: clamp(3.5rem, 6vw, 4.5rem);
    color: var(--accent-green);
    text-align: center;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    text-align: center;
    color: var(--text-main);
    opacity: 0.7;
    margin-bottom: 2.5rem;
    font-size: 0.95rem;
  }

  .rsvp-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  label {
    font-size: 0.9rem;
    color: var(--text-main);
    font-weight: 500;
  }

  input[type="text"],
  input[type="email"],
  textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(27, 51, 32, 0.2);
    border-radius: 4px;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--text-main);
    background-color: var(--bg-color);
    transition: border-color 0.2s ease, outline 0.2s ease;
  }

  input[type="text"]:focus,
  input[type="email"]:focus,
  textarea:focus {
    outline: 2px solid var(--accent-green);
    border-color: transparent;
  }

  .radio-group {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .radio-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-weight: normal;
  }

  input[type="radio"] {
    accent-color: var(--accent-green);
    width: 1.1rem;
    height: 1.1rem;
    cursor: pointer;
  }

  .submit-button {
    margin-top: 1rem;
    padding: 1rem 2rem;
    background-color: var(--accent-green);
    color: #1B3320;
    border: none;
    border-radius: 4px;
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .submit-button:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }
</style>