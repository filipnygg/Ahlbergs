---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
---

<Layout title="Galleri | Ahlbergs Bröllop">
  <main class="page-container">
    <Navigation />
    
    <article class="content-wrapper">
      <h1 class="page-title">Ögonblick & Minnen</h1>
      <p class="subtitle">Hjälp oss att fånga dagens magi. Ladda gärna upp de foton och videor ni tar!</p>
      
      <div class="upload-section">
        <!-- This button will trigger the Cloudinary Widget -->
        <button id="upload_widget" class="upload-button">
          <svg class="upload-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="17 8 12 3 7 8"></polyline>
            <line x1="12" y1="3" x2="12" y2="15"></line>
          </svg>
          Ladda upp era foton
        </button>
      </div>

      <hr class="divider" />

      <!-- The grid where uploaded photos will eventually display -->
      <div id="photo-grid" class="photo-grid"></div>

    </article>
  </main>
</Layout>

<!-- Cloudinary Upload Widget Script -->
<script src="https://upload-widget.cloudinary.com/global/all.js" type="text/javascript"></script>  

<script type="text/javascript">
  const cloudName = 'dcj1qgxhj';
  const uploadPreset = 'ahlbergs_wedding';
  const galleryTag = 'ahlbergs_guest_photos'; // This groups your photos together

  // 1. Configure the Upload Widget
  const myWidget = cloudinary.createUploadWidget({
    cloudName: cloudName, 
    uploadPreset: uploadPreset,
    tags: [galleryTag], // Tags the photo automatically on upload
    sources: ['local', 'camera'],
    multiple: true,
    clientAllowedFormats: ['png', 'jpeg', 'jpg', 'heic', 'heif', 'webp'],
    maxImageFileSize: 10000000,
    theme: "minimal"
  }, (error, result) => { 
    if (!error && result && result.event === "success") { 
      console.log('Upload successful!'); 
      loadGallery(); // Instantly reloads the grid after a new upload
    }
  });

  document.getElementById("upload_widget").addEventListener("click", function(e){
    e.preventDefault();
    myWidget.open();
  }, false);

  // 2. Fetch and Display the Gallery
  async function loadGallery() {
    const grid = document.getElementById('photo-grid');
    grid.innerHTML = '<p style="text-align:center; grid-column: 1/-1; color: var(--text-main); opacity: 0.6;">Laddar foton...</p>';
    
    try {
      // Ask Cloudinary for the list of photos with our specific tag
      const response = await fetch(`https://res.cloudinary.com/${cloudName}/image/list/${galleryTag}.json`);
      if (!response.ok) throw new Error('No photos found or list restricted');
      
      const data = await response.json();
      grid.innerHTML = ''; // Clear loading text
      
      if (data.resources.length === 0) {
        grid.innerHTML = '<p style="text-align:center; grid-column: 1/-1; color: var(--text-main); opacity: 0.6;">Inga foton än. Bli den första att ladda upp!</p>';
        return;
      }

      // Build an image card for each photo found
      data.resources.forEach(img => {
        // Automatically resizes and optimizes the image for fast loading
        const imgUrl = `https://res.cloudinary.com/${cloudName}/image/upload/w_500,c_fill,ar_4:5,f_auto,q_auto/v${img.version}/${img.public_id}.${img.format}`;
        
        const card = document.createElement('div');
        card.className = 'photo-card';
        card.innerHTML = `<img src="${imgUrl}" alt="Gästminne" style="width: 100%; height: 100%; object-fit: cover;" loading="lazy" />`;
        grid.appendChild(card);
      });
    } catch (error) {
      console.error('Error loading gallery:', error);
      grid.innerHTML = '<p style="text-align:center; grid-column: 1/-1; color: var(--text-main); opacity: 0.6;">Redo att ta emot foton!</p>';
    }
  }

  // Load the gallery automatically when the page opens
  document.addEventListener('DOMContentLoaded', loadGallery);
</script>

<style>
  .page-container {
    min-height: 100vh;
    padding: clamp(2rem, 5vw, 4rem) 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .content-wrapper {
    width: 100%;
    max-width: 1000px;
    background: #FFFFFF;
    padding: clamp(2rem, 5vw, 4rem);
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    margin-top: 2rem;
  }

  .page-title {
    font-family: var(--font-heading); /* Tillagt för att aktivera skrivstilen */
    font-size: clamp(3.5rem, 6vw, 4.5rem);
    color: var(--accent-green);
    text-align: center;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    text-align: center;
    color: var(--text-main);
    opacity: 0.7;
    margin-bottom: 2.5rem;
    font-size: 1rem;
  }

  .upload-section {
    display: flex;
    justify-content: center;
    margin-bottom: 3rem;
  }

  .upload-button {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2.5rem;
    background-color: var(--accent-green);
    color: #1B3320;
    border: none;
    border-radius: 4px;
    font-size: 1.1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: transform 0.2s ease, opacity 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 4px 15px rgba(168, 213, 186, 0.3);
  }

  .upload-button:hover {
    opacity: 0.95;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(168, 213, 186, 0.5);
  }

  .upload-icon {
    width: 20px;
    height: 20px;
  }

  .divider {
    border: 0;
    height: 1px;
    background: var(--accent-green);
    opacity: 0.2;
    margin: 3rem 0;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1.5rem;
  }
</style>