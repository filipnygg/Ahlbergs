---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
---

<Layout title="Information | Ahlbergs Wedding">
  <main class="page-container">
    <Navigation />
    
    <article class="content-wrapper">
      <h1 class="page-title">Wedding Information</h1>
      
      <section class="info-section">
        <h2 class="section-heading">Dress Code</h2>
        <p class="section-text">
          We request that our guests dress in formal attire. 
          For men, this means a dark suit and tie. For women, an elegant cocktail dress, evening gown, or formal dress suit.
        </p>
      </section>

      <hr class="divider" />

      <section class="info-section">
        <h2 class="section-heading">Venues & Travel</h2>
        
        <div class="location-split">
          <div class="location-card">
            <h3 class="travel-subheading">The Ceremony</h3>
            <p class="info-text">
              <strong>14:00</strong><br />
              <strong>Mariakyrkan</strong><br />
              Olofsgatan 4<br />
              Sigtuna
            </p>
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2017.8754693434623!2d17.720324278035612!3d59.61843457475565!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x465fba56ec379625%3A0x1b4b780be9e51430!2sMariakyrkan!5e0!3m2!1ssv!2sse!4v1782212316671!5m2!1ssv!2sse" 
              width="100%" 
              height="250" 
              style="border:0; border-radius: 4px; margin-top: 1rem;" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade">
            </iframe>
          </div>

          <div class="location-card">
            <h3 class="travel-subheading">The Reception</h3>
            <p class="info-text">
              <strong>16:30</strong><br />
              <strong>Herresta Lada</strong><br />
              Odensala Herresta 236<br />
              Märsta
            </p>
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2015.89163615627!2d17.843297578036868!3d59.65145277477203!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x465fbeacf29184fd%3A0x6c643d8e3d98d084!2sHerresta%20Lada!5e0!3m2!1ssv!2sse!4v1782212611834!5m2!1ssv!2sse" 
              width="100%" 
              height="250" 
              style="border:0; border-radius: 4px; margin-top: 1rem;" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade">
            </iframe>
          </div>
        </div>

        <div class="travel-block">
          <h3 class="travel-subheading">Accommodations</h3>
          <p class="section-text">
            If you are traveling from out of town, we recommend staying at <strong>[Insert Hotel Name]</strong>. We have arranged a small block of rooms under "Ahlbergs Wedding". Please book before [Insert Date] to secure the rate.
          </p>
        </div>

        <div class="travel-block">
          <h3 class="travel-subheading">Transportation & Parking</h3>
          <p class="section-text">
            Free parking is available at both locations. For your convenience, we have arranged a bus to transport guests between the ceremony at Mariakyrkan and the reception at Herresta Lada.
          </p>
        </div>
      </section>
      
      <hr class="divider" />

      <section class="info-section">
        <h2 class="section-heading">Toastmasters</h2>
        <p class="section-text">
          Our wonderful toastmasters will be guiding the evening's celebrations. 
          If you would like to give a speech or perform, please reach out to them directly well in advance.
        </p>
        <div class="toastmaster-cards">
          <div class="card">
            <h3 class="card-name">Toastmaster Name 1</h3>
            <a href="mailto:email1@example.com" class="card-contact">email1@example.com</a>
            <p class="card-contact">+46 70 000 00 00</p>
          </div>
          <div class="card">
            <h3 class="card-name">Toastmaster Name 2</h3>
            <a href="mailto:email2@example.com" class="card-contact">email2@example.com</a>
            <p class="card-contact">+46 70 000 00 01</p>
          </div>
        </div>
      </section>

      <hr class="divider" />

      <section class="info-section">
        <h2 class="section-heading">Gifts</h2>
        <p class="section-text">
          Your presence at our wedding is the greatest gift of all. However, if you wish to honor us with a gift, please visit our Registry page for more information.
        </p>
      </section>

      <hr class="divider" />

      <section class="info-section">
        <h2 class="section-heading">Good to Know (FAQ)</h2>
        <div class="faq-grid">
          
          <div class="faq-item">
            <h3 class="faq-question">Are children welcome?</h3>
            <p class="faq-answer">
              We adore your little ones and warmly welcome them to join us for the ceremony at Mariakyrkan. However, to allow all of our guests to relax and enjoy the evening, our reception at Herresta Lada will be an adults-only celebration. We hope this advance notice allows you to arrange childcare so you can celebrate with us into the night!
            </p>
          </div>

          <div class="faq-item">
            <h3 class="faq-question">Can I bring a plus one?</h3>
            <p class="faq-answer">
              Due to the capacity of our venue, we are only able to accommodate the guests who are formally named on your invitation.
            </p>
          </div>

          <div class="faq-item">
            <h3 class="faq-question">Can I take photos during the ceremony?</h3>
            <p class="faq-answer">
              Yes! We would love for you to capture the joy of our day. We just ask that you remain mindful of our professional photographer so they have the space to get the perfect shots. Feel free to share your photos with us later!
            </p>
          </div>

          <div class="faq-item">
            <h3 class="faq-question">What should I consider regarding weather and footwear?</h3>
            <p class="faq-answer">
              October in Sweden can be crisp! The initial reception mingle will take place outdoors before we move inside the barn for dinner and dancing. We highly recommend bringing a warm jacket or shawl, and choosing footwear that is comfortable for walking on rustic or uneven ground.
            </p>
          </div>

        </div>
      </section>
    </article>
  </main>
</Layout>

<style>
  .page-container {
    min-height: 100vh;
    padding: clamp(2rem, 5vw, 4rem) 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .content-wrapper {
    width: 100%;
    max-width: 800px;
    background: #FFFFFF;
    padding: clamp(2rem, 5vw, 4rem);
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    margin-top: 2rem;
  }

  .page-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: var(--accent-green);
    text-align: center;
    margin-bottom: 3rem;
  }

  .info-section {
    margin-bottom: 2.5rem;
  }

  .section-heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 2.5rem);
    color: var(--text-main);
    margin-bottom: 1.5rem;
  }

  .section-text {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-main);
    opacity: 0.85;
  }

  .divider {
    border: 0;
    height: 1px;
    background: var(--accent-green);
    opacity: 0.3;
    margin: 2.5rem 0;
  }

  /* Flexbox logic for side-by-side maps */
  .location-split {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 2rem;
    width: 100%;
  }

  @media (min-width: 600px) {
    .location-split {
      flex-direction: row;
    }
  }

  .location-card {
    flex: 1;
    background-color: var(--bg-color);
    border: 1px dashed var(--accent-green);
    border-radius: 8px;
    padding: 1.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1rem;
  }

  .travel-block {
    margin-top: 2rem;
    text-align: center;
  }

  .travel-subheading {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    color: var(--text-main);
    margin-bottom: 0.5rem;
  }

  .info-text {
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--text-main);
  }

  .toastmaster-cards {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    margin-top: 1.5rem;
  }

  .card {
    flex: 1;
    min-width: 250px;
    padding: 1.5rem;
    border: 1px solid rgba(168, 213, 186, 0.4);
    border-radius: 6px;
    background-color: var(--bg-color);
  }

  .card-name {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: var(--text-main);
    margin-bottom: 0.5rem;
  }

  .card-contact {
    display: block;
    font-size: 0.9rem;
    color: var(--text-main);
    opacity: 0.7;
    text-decoration: none;
    margin-bottom: 0.25rem;
  }

  a.card-contact:hover {
    color: var(--accent-green);
    opacity: 1;
  }

  /* FAQ Styles */
  .faq-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .faq-item {
    background-color: #FAFAFA;
    padding: 1.5rem;
    border-radius: 6px;
    border-left: 3px solid var(--accent-green);
  }

  .faq-question {
    font-size: 1.1rem;
    color: var(--text-main);
    margin-bottom: 0.5rem;
    font-weight: 600;
  }

  .faq-answer {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-main);
    opacity: 0.85;
  }

  @media (min-width: 768px) {
    .faq-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>