---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
---

<Layout title="Information | Ahlbergs Wedding">
  <main class="page-container">
    <Navigation />
    
    <article class="content-wrapper">
      <h1 class="page-title">Wedding Information</h1>
      
      <section class="info-section">
        <h2 class="section-heading">Dress Code</h2>
        <p class="section-text">
          We request that our guests dress in formal attire. 
          For men, this means a dark suit and tie. For women, an elegant cocktail dress, evening gown, or formal dress suit.
        </p>
      </section>

      <hr class="divider" />

      <section class="info-section">
        <h2 class="section-heading">Venues & Travel</h2>
        
        <div class="location-split">
          <div class="location-card">
            <h3 class="travel-subheading">The Ceremony</h3>
            <p class="info-text">
              <strong>Mariakyrkan</strong><br />
              Olofsgatan 4<br />
              Sigtuna
            </p>
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2017.8754693434623!2d17.720324278035612!3d59.61843457475565!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x465fba56ec379625%3A0x1b4b780be9e51430!2sMariakyrkan!5e0!3m2!1ssv!2sse!4v1782212316671!5m2!1ssv!2sse" 
              width="100%" 
              height="250" 
              style="border:0; border-radius: 4px; margin-top: 1rem;" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade">
            </iframe>
          </div>

          <div class="location-card">
            <h3 class="travel-subheading">The Reception</h3>
            <p class="info-text">
              <strong>Herresta Lada</strong><br />
              Odensala Herresta 236<br />
              Märsta
            </p>
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2015.89163615627!2d17.843297578036868!3d59.65145277477203!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x465fbeacf29184fd%3A0x6c643d8e3d98d084!2sHerresta%20Lada!5e0!3m2!1ssv!2sse!4v1782212611834!5m2!1ssv!2sse" 
              width="100%" 
              height="250" 
              style="border:0; border-radius: 4px; margin-top: 1rem;" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade">
            </iframe>
          </div>
        </div>

        <div class="travel-block">
          <h3 class="travel-subheading">Accommodations</h3>
          <p class="section-text">
            If you are traveling from out of town, we recommend staying at <strong>Scandic Arlandastad or Hotell Kristina</strong>. 
          </p>
        </div>

        <div class="travel-block">
          <h3 class="travel-subheading">Transportation & Parking</h3>
          <p class="section-text">
            Free parking is available at both locations. For your convenience, we have arranged a bus to transport guests between the ceremony at Mariakyrkan and the reception at Herresta Lada.
          </p>
        </div>
      </section>
      
      <hr class="divider" />

      <section class="info-section">
        <h2 class="section-heading">Toastmasters</h2>
        <p class="section-text">
          Our wonderful toastmasters will be guiding the evening's celebrations. 
          If you would like to give a speech or perform, please reach out to them directly well in advance.
        </p>
        <div class="toastmaster-cards">
          <div class="card">
            <h3 class="card-name">Toastmaster Name 1</h3>
            <a href="mailto:email1@example.com" class="card-contact">email1@example.com</a>
            <p class="card-contact">+46 70 000 00 00</p>
          </div>
          <div class="card">
            <h3 class="card-name">Toastmaster Name 2</h3>
            <a href="mailto:email2@example.com" class="card-contact">email2@example.com</a>
            <p class="card-contact">+46 70 000 00 01</p>
          </div>
        </div>
      </section>

      <hr class="divider" />

      <section class="info-section">
        <h2 class="section-heading">Gifts</h2>
        <p class="section-text">
          Your presence at our wedding is the greatest gift of all. However, if you wish to honor us with a gift, please visit our Registry page for more information.
        </p>
      </section>
    </article>
  </main>
</Layout>

<style>
  .page-container {
    min-height: 100vh;
    padding: clamp(2rem, 5vw, 4rem) 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .content-wrapper {
    width: 100%;
    max-width: 800px;
    background: #FFFFFF;
    padding: clamp(2rem, 5vw, 4rem);
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    margin-top: 2rem;
  }

  .page-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: var(--accent-green);
    text-align: center;
    margin-bottom: 3rem;
  }

  .info-section {
    margin-bottom: 2.5rem;
  }

  /* Unified sizing for all main sections */
  .section-heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 2.5rem);
    color: var(--text-main);
    margin-bottom: 1.5rem;
  }

  .section-text {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-main);
    opacity: 0.85;
  }

  .divider {
    border: 0;
    height: 1px;
    background: var(--accent-green);
    opacity: 0.3;
    margin: 2.5rem 0;
  }

  /* Flexbox logic for side-by-side maps */
  .location-split {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 2rem;
    width: 100%;
  }

  @media (min-width: 600px) {
    .location-split {
      flex-direction: row;
    }
  }

  .location-card {
    flex: 1;
    background-color: var(--bg-color);
    border: 1px dashed var(--accent-green);
    border-radius: 8px;
    padding: 1.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1rem;
  }

  .travel-block {
    margin-top: 2rem;
    text-align: center;
  }

  /* Cursive styling for the subheadings */
  .travel-subheading {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    color: var(--text-main);
    margin-bottom: 0.5rem;
  }

  .info-text {
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--text-main);
  }

  .toastmaster-cards {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    margin-top: 1.5rem;
  }

  .card {
    flex: 1;
    min-width: 250px;
    padding: 1.5rem;
    border: 1px solid rgba(168, 213, 186, 0.4);
    border-radius: 6px;
    background-color: var(--bg-color);
  }

  /* Cursive styling applied to Toastmaster names */
  .card-name {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: var(--text-main);
    margin-bottom: 0.5rem;
  }

  .card-contact {
    display: block;
    font-size: 0.9rem;
    color: var(--text-main);
    opacity: 0.7;
    text-decoration: none;
    margin-bottom: 0.25rem;
  }

  a.card-contact:hover {
    color: var(--accent-green);
    opacity: 1;
  }
</style>