---
import Layout from '../layouts/Layout.astro';
import siteData from '../data/site.json';
---

<Layout title="Välkommen | Ahlbergs Bröllop">
  <main class="welcome-overlay">
    
    <div class="welcome-title-wrapper">
      <svg class="decorative-leaf left-leaf" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
        <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"></path>
        <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path>
      </svg>

      <h1 class="welcome-title">{siteData.siteName}</h1>

      <svg class="decorative-leaf right-leaf" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
        <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"></path>
        <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path>
      </svg>
    </div>

    <form class="lock-form" action="/api/login" method="POST">
      <input type="password" name="password" required placeholder="Ange gästlösenord" />
      <button type="submit" class="submit-button">Gå in</button>
    </form>
    
    <p id="error-message" class="error-message" style="display: none;">Fel lösenord. Vänligen försök igen.</p>

  </main>
</Layout>

<script>
  if (window.location.search.includes('error=1')) {
    document.getElementById('error-message').style.display = 'block';
  }
</script>

<style>
  .welcome-overlay {
    width: 100vw;
    min-height: 100vh;
    background-image: linear-gradient(rgba(250, 250, 250, 0.85), rgba(250, 250, 250, 0.85)), url('/assets/splash-bg.jpg');
    background-size: cover;
    background-position: center;
    background-color: var(--bg-color);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 1rem;
  }

  .welcome-title-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(0.5rem, 3vw, 2rem);
    margin-bottom: 2rem;
  }

  .decorative-leaf {
    width: clamp(2rem, 6vw, 4rem);
    height: clamp(2rem, 6vw, 4rem);
    color: #000000; 
    opacity: 0.8;
  }

  .left-leaf { transform: scaleX(-1) rotate(-15deg); }
  .right-leaf { transform: rotate(-15deg); }

  .welcome-title {
    font-family: var(--font-heading); /* Tillagt för att aktivera skrivstilen */
    font-size: clamp(3.5rem, 8vw, 6rem); 
    color: #000000; 
    text-align: center;
    line-height: 1.1;
  }

  .lock-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
    max-width: 300px;
    margin-top: 1rem;
  }

  .lock-form input {
    padding: 0.8rem 1rem;
    border: 1px solid rgba(0,0,0,0.2);
    border-radius: 4px;
    font-size: 1rem;
    font-family: var(--font-body);
    text-align: center;
    background: rgba(255, 255, 255, 0.9);
  }

  .lock-form input:focus {
    outline: 2px solid var(--accent-green);
    border-color: transparent;
  }

  .submit-button {
    padding: 0.8rem 1rem;
    background-color: var(--accent-green);
    color: #1B3320;
    border: none;
    border-radius: 4px;
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .submit-button:hover { opacity: 0.9; }

  .error-message {
    color: #d9534f;
    margin-top: 1rem;
    font-size: 0.9rem;
    font-weight: 500;
    background: rgba(255,255,255,0.9);
    padding: 0.5rem 1rem;
    border-radius: 4px;
  }
</style>