---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
---

<Layout title="Home | Ahlbergs Wedding">
  <main class="page-container">
    <Navigation />
    
    <section class="hero-section">
      <img src="/assets/hero-couple.jpg" alt="Ahlbergs Wedding" class="hero-image" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
      <div class="image-placeholder-frame" style="display: none;">
        <p class="frame-text">Add your photo to public/assets/hero-couple.jpg</p>
      </div>
    </section>

    <section class="home-content">
      <div class="info-block">
        <h2 class="welcome-heading">Filip & Tindra</h2>
        <p class="welcome-text">
          <strong>October 10th, 2026</strong><br /><br />
          We are so excited to celebrate with you. Use the menu above to RSVP, view the schedule for the day, or browse our information page.
        </p>
      </div>

      <hr class="divider" />

      <div class="spotify-block">
        <svg class="spotify-icon" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.54.659.301 1.02zM19.32 14.1c-.3.42-.84.54-1.26.24-3.36-2.04-8.52-2.64-12.54-1.44-.48.12-1.02-.12-1.14-.6-.12-.48.12-1.02.6-1.14 4.56-1.32 10.32-.66 14.1 1.68.48.24.6.84.24 1.26zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.781-.18-.6.18-1.2.78-1.38 4.2-1.32 11.28-1.02 15.721 1.62.54.3.72.96.42 1.5-.3.54-.96.72-1.5.42z"></path>
        </svg>
        <h3 class="spotify-heading">Help Us Build the Playlist</h3>
        <p class="spotify-text">Add your favorite dancing songs to our collaborative Spotify playlist so we can celebrate all night.</p>
        
        <!-- Insert Spotify Link Here -->
        <a href="https://open.spotify.com/playlist/YOUR_LINK_HERE" target="_blank" rel="noopener noreferrer" class="spotify-button">
          Open Spotify Playlist
        </a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .page-container {
    min-height: 100vh;
    padding: clamp(2rem, 5vw, 4rem) 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
  }

  .hero-section {
    width: 100%;
    max-width: 900px;
    padding: 0 1rem;
    margin-bottom: 3rem;
  }

  .hero-image {
    width: 100%;
    height: auto;
    border-radius: 4px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    display: block;
  }

  .image-placeholder-frame {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #EAEAEA;
    border: 1px dashed var(--accent-green);
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 4px;
    text-align: center;
    padding: 1rem;
  }

  .home-content {
    width: 100%;
    max-width: 800px;
    background: #FFFFFF;
    padding: clamp(2rem, 5vw, 4rem);
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    text-align: center;
  }

  .welcome-heading {
    font-family: var(--font-heading);
    font-size: 2.2rem;
    color: var(--text-main);
    margin-bottom: 1rem;
  }

  .welcome-text {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text-main);
    opacity: 0.8;
  }

  .divider {
    border: 0;
    height: 1px;
    background: var(--accent-green);
    opacity: 0.2;
    margin: 2.5rem 0;
  }

  .spotify-icon {
    width: 48px;
    height: 48px;
    color: #1DB954;
    margin-bottom: 1rem;
  }

  .spotify-heading {
    font-size: 1.5rem;
    color: var(--text-main);
    margin-bottom: 0.5rem;
  }

  .spotify-text {
    font-size: 0.95rem;
    color: var(--text-main);
    opacity: 0.8;
    margin-bottom: 1.5rem;
  }

  .spotify-button {
    display: inline-block;
    padding: 0.8rem 2rem;
    background-color: #1DB954;
    color: #FFFFFF;
    text-decoration: none;
    border-radius: 50px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 4px 15px rgba(29, 185, 84, 0.3);
  }

  .spotify-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(29, 185, 84, 0.4);
  }
</style>