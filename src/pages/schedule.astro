---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
---

<Layout title="Schema | Ahlbergs Bröllop">
  <main class="page-container">
    <Navigation />
    
    <article class="content-wrapper">
      <h1 class="page-title">Dagens Schema</h1>
      <p class="subtitle">10 oktober 2026</p>
      
      <div class="timeline">
        
        <div class="timeline-item">
          <div class="timeline-time">14:00</div>
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <h3 class="event-title">Vigsel</h3>
            <span class="event-location">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              Mariakyrkan
            </span>
            <p class="event-description">Vigseln äger rum i Mariakyrkan. Vänligen anländ 15 minuter innan för att i lugn och ro hitta era platser.</p>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-time">16:00</div>
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <h3 class="event-title">Brudskål & Mingel</h3>
            <span class="event-location">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              Herresta Lada
            </span>
            <p class="event-description">Vi samlas vid ladan för brudskål, mingel och tilltugg innan vi sätter oss till bords.</p>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-time">18:00</div>
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <h3 class="event-title">Middag</h3>
            <p class="event-description">Slå er ner för en fantastisk middag fylld med tal, skratt och trevligt sällskap.</p>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-time">21:00</div>
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <h3 class="event-title">Efterrätt & Dans</h3>
            <p class="event-description">Vi kör lite efterrätt och öppnar därefter dansgolvet för att fira in i natten!</p>
          </div>
        </div>

      </div>
    </article>
  </main>
</Layout>

<style>
  .page-container {
    min-height: 100vh;
    padding: clamp(2rem, 5vw, 4rem) 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }
  .content-wrapper {
    width: 100%;
    max-width: 800px;
    background: #FFFFFF;
    padding: clamp(2rem, 5vw, 4rem);
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    margin-top: 2rem;
  }
  .page-title {
    font-size: clamp(3rem, 6vw, 4rem);
    color: var(--accent-green);
    text-align: center;
    margin-bottom: 0.5rem;
    font-family: var(--font-heading);
  }
  .subtitle {
    text-align: center;
    color: var(--text-main);
    opacity: 0.7;
    margin-bottom: 3.5rem;
    font-size: 1.1rem;
    font-weight: 500;
  }
  .timeline {
    position: relative;
    max-width: 600px;
    margin: 0 auto;
    padding-left: 2rem;
  }
  .timeline::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 2rem;
    width: 2px;
    background-color: rgba(168, 213, 186, 0.4);
    transform: translateX(-50%);
  }
  .timeline-item {
    position: relative;
    display: flex;
    flex-direction: column;
    margin-bottom: 3rem;
    padding-left: 2.5rem;
  }
  .timeline-item:last-child {
    margin-bottom: 0;
  }
  .timeline-time {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--accent-green);
    margin-bottom: 0.25rem;
  }
  .timeline-marker {
    position: absolute;
    left: 0;
    top: 0.25rem;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background-color: var(--bg-color);
    border: 3px solid var(--accent-green);
    transform: translateX(-50%);
    z-index: 2;
  }
  .timeline-content {
    display: flex;
    flex-direction: column;
  }
  .event-title {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    color: var(--text-main);
    margin-bottom: 0.25rem;
    line-height: 1.2;
  }
  .event-location {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent-green);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.75rem;
  }
  .event-location svg {
    width: 16px;
    height: 16px;
    opacity: 0.8;
  }
  .event-description {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-main);
    opacity: 0.8;
  }
  @media (min-width: 600px) {
    .timeline {
      padding-left: 0;
    }
    .timeline::before {
      left: 100px;
    }
    .timeline-item {
      flex-direction: row;
      padding-left: 130px;
    }
    .timeline-time {
      position: absolute;
      left: 0;
      top: 0.25rem;
      width: 80px;
      text-align: right;
      margin-bottom: 0;
    }
    .timeline-marker {
      left: 100px;
    }
  }
</style>